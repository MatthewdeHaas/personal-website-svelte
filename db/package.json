  "scripts": {
    "migrate": "tsx migrate.ts",
    "migrate:prod": "dotenv -e ../infra/.env -- sh -c 'DATABASE_URL=postgres://postgres:password@$DROPLET_IP:5432/personal-site tsx migrate.ts'",
    "seed": "tsx seed.ts",
